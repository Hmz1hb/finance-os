# Values live in AWS SSM Parameter Store at /finance-os/prod/*
# infra/userdata.sh fetches them and writes /opt/finance-os/.env on the EC2 host.
# Do NOT commit real values.

DATABASE_URL=postgresql://postgres:REPLACE@db:5432/finance_os?schema=public
POSTGRES_PASSWORD=REPLACE
AUTH_SECRET=REPLACE
NEXTAUTH_URL=https://your-domain.example.com
ADMIN_USER=REPLACE
ADMIN_PASSWORD=REPLACE_BCRYPT_HASH
AWS_REGION=eu-central-1
S3_BUCKET_NAME=your-private-receipts-bucket
BEDROCK_MODEL_ID=eu.anthropic.claude-haiku-4-5-20251001-v1:0
TUNNEL_TOKEN=REPLACE
